# Authentication: credentials are NOT stored here. Run `discord-mcp login`
# once to open a browser window and sign in to Discord. Your session is
# encrypted with a key held in your OS keyring.

# Optional: run Playwright headless (default: true)
DISCORD_HEADLESS=true

# Optional: disallow send_message (default: true)
DISCORD_READ_ONLY=true

# Optional: how many parallel browsers the MCP server keeps warm (default: 4)
DISCORD_POOL_SIZE=4

# Optional: default limits for tools
MAX_MESSAGES_PER_CHANNEL=200
DEFAULT_HOURS_BACK=24
